APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
HTTPX_LOG_LEVEL=WARNING
LOG_RETENTION_DAYS=30
LOG_CLEANUP_INTERVAL_SEC=3600
AUDIT_EVENTS_ENABLED=true
AUDIT_CAPTURE_FULL_TEXT=true
SERVICE_NAME=fandogh-bridge
TZ=Asia/Tehran
APP_LANG=fa

TELEGRAM_BOT_TOKEN=REPLACE_ME_TELEGRAM_TOKEN
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_FILE_BASE_URL=https://api.telegram.org/file
TELEGRAM_POLL_TIMEOUT_SEC=30
TELEGRAM_ALLOWED_UPDATES=["message","callback_query","pre_checkout_query"]
TELEGRAM_ENABLE_BUTTON_STYLES=false
TELEGRAM_BUTTON_STYLE_MODE=none
TELEGRAM_SET_COMMANDS_ON_START=true
TELEGRAM_SET_MENU_BUTTON_ON_START=true

BALE_BOT_TOKEN=REPLACE_ME_BALE_TOKEN
BALE_API_BASE_URL=https://tapi.bale.ai
BALE_FILE_BASE_URL=https://tapi.bale.ai/file
BALE_POLL_TIMEOUT_SEC=30
BALE_ALLOWED_UPDATES=["message","callback_query","pre_checkout_query"]

MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=fandogh
MYSQL_USER=fandogh_app
MYSQL_PASSWORD=CHANGE_ME_APP_PASSWORD
DB_URL=mysql+aiomysql://fandogh_app:CHANGE_ME_APP_PASSWORD@mysql:3306/fandogh

MEDIA_TMP_DIR=./app_tmp_media
MEDIA_MAX_DOWNLOAD_MB=20
MEDIA_MAX_UPLOAD_MB=20
MEDIA_DELETE_AFTER_SEND=true

QUEUE_RETRY_ENABLED=true
QUEUE_RETRY_MAX_HOURS=24
QUEUE_RETRY_BASE_SEC=5
QUEUE_RETRY_MAX_SEC=300
QUEUE_WORKER_INTERVAL_SEC=2

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MSG_PER_MIN=40
RATE_LIMIT_MEDIA_PER_MIN=12

MESSAGE_MAX_TEXT_LEN=0
FORWARD_CAPTION_TEMPLATE="[{platform}] از {display_name} (@{username}) | ID: {bridge_id}"

BRIDGE_ID_PREFIX=FDG
BRIDGE_ID_LENGTH=10

SHOW_SENDER_PLATFORM=true
SHOW_SENDER_USERNAME=true
SHOW_SENDER_DISPLAY_NAME=true

METRICS_ENABLED=false
HEALTHCHECK_ENABLED=false

ADMIN_IDS=
TELEGRAM_ADMIN_CHANNEL_ID=
BALE_WALLET_PROVIDER_TOKEN=
TELEGRAM_TON_PAY_ENABLED=false
TELEGRAM_TON_PAY_API_TOKEN=
TELEGRAM_TON_PAY_API_BASE_URL=https://pay.crypt.bot/api
TELEGRAM_TON_PAY_ASSET=TON
TELEGRAM_TON_PAY_POLL_INTERVAL_SEC=15
TELEGRAM_TON_PAY_TIMEOUT_SEC=12
TON_RATE_API_ENABLED=true
TON_RATE_API_URL=https://data-api.binance.vision/api/v3/ticker/price
TON_RATE_API_SYMBOL=TONUSDT
TON_RATE_API_CACHE_SEC=300
TON_RATE_API_TIMEOUT_SEC=8
USDT_FIXED_TOMAN_RATE=150000
SALES_CONFIG_PATH=./config/sales_catalog.json
DOCKER_IMAGE_TAG=fandogh-bridge:latest

ELASTIC_STACK_VERSION=8.14.3
ELASTIC_PASSWORD=CHANGE_ME_ELASTIC_PASSWORD
KIBANA_SYSTEM_PASSWORD=CHANGE_ME_KIBANA_SYSTEM_PASSWORD
ELASTIC_INGEST_USERNAME=fandogh_ingest
ELASTIC_INGEST_PASSWORD=CHANGE_ME_INGEST_PASSWORD
KIBANA_VIEWER_USERNAME=fandogh_observer
KIBANA_VIEWER_PASSWORD=CHANGE_ME_KIBANA_PASSWORD
KIBANA_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM_KIBANA_KEY
DOCKER_CONTAINERS_PATH=/var/lib/docker/containers

DEV_WATCH_COMMAND=
DEV_WATCH_PATHS=src,.env,pyproject.toml,requirements.txt
DEV_WATCH_IGNORE_DIRS=.git,.venv,.pytest_cache,__pycache__,app_data,app_tmp_media,data
DEV_WATCH_DEBOUNCE_MS=700
DEV_WATCH_POLL_DELAY_MS=300
DEV_WATCH_FORCE_POLLING=
DEV_WATCH_TERM_TIMEOUT_SEC=10
DEV_WATCH_RUST_TIMEOUT_MS=1000
